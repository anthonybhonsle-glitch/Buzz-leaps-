// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: scores
// Document ID: auto-generated
// Fields:
//   - userId: string (required) - The UID of the user
//   - userName: string (required) - The display name
//   - score: number (required, positive) - The score achieved
//   - mode: string (required, enum: classic, timed, zen) - The game mode
//   - timestamp: timestamp (required) - When the score was achieved
//
// Collection: users
// Document ID: userId
// Fields:
//   - uid: string (required) - The UID of the user
//   - displayName: string (required) - The display name
//   - photoURL: string (optional) - Profile picture
//   - highScore: number (optional) - Personal high score
//   - isPro: boolean (optional) - Pro status
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "anthonybhonsle@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidScore(data) {
      return data.userId is string && data.userId == request.auth.uid &&
             data.userName is string && data.userName.size() > 0 && data.userName.size() < 50 &&
             data.score is number && data.score >= 0 &&
             data.mode in ['classic', 'timed', 'zen'] &&
             data.timestamp is timestamp;
    }

    function isValidUser(data) {
      return data.uid is string && data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 50 &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() < 500)) &&
             (!('highScore' in data) || (data.highScore is number && data.highScore >= 0)) &&
             (!('isPro' in data) || data.isPro is bool);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /scores/{scoreId} {
      allow read: if true; // Public leaderboard
      allow create: if isAuthenticated() && isValidScore(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated(); // Allow users to see each other's basic profile for leaderboard
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                      (!('role' in request.resource.data) || request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();
    }
  }
}
